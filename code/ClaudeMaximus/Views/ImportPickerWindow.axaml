<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:ClaudeMaximus.ViewModels"
        xmlns:views="using:ClaudeMaximus.Views"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        x:Class="ClaudeMaximus.Views.ImportPickerWindow"
        x:DataType="vm:ImportPickerViewModel"
        Title="Import Claude Sessions"
        Width="700" Height="650"
        MinWidth="500" MinHeight="500"
        WindowStartupLocation="CenterOwner">

    <DockPanel Margin="12">

        <!-- Source directory selector with Global toggle -->
        <DockPanel DockPanel.Dock="Top" Margin="0,0,0,4" x:CompileBindings="False">
            <TextBlock DockPanel.Dock="Left" Text="Scan from:" VerticalAlignment="Center"
                       Margin="0,0,8,0" Width="75"/>
            <CheckBox DockPanel.Dock="Right" Content="Global" Margin="8,0,0,0"
                      IsChecked="{Binding IsGlobalSearch}"
                      IsVisible="{Binding CanUseGlobalSearch}"
                      VerticalAlignment="Center" FontSize="12"
                      ToolTip.Tip="Search across all projects (via Tessyn daemon)"/>
            <ComboBox ItemsSource="{Binding SourceDirectories}"
                      SelectedItem="{Binding SelectedSource}"
                      IsEnabled="{Binding !IsGlobalSearch}"
                      HorizontalAlignment="Stretch"/>
        </DockPanel>

        <!-- Import target selector (always shown) -->
        <DockPanel DockPanel.Dock="Top" Margin="0,0,0,8" x:CompileBindings="False">
            <TextBlock DockPanel.Dock="Left" Text="Import into:" VerticalAlignment="Center"
                       Margin="0,0,8,0" Width="75"/>
            <ComboBox ItemsSource="{Binding ImportTargets}"
                      SelectedItem="{Binding SelectedImportTarget}"
                      HorizontalAlignment="Stretch"/>
        </DockPanel>

        <!-- Cross-project warning banner -->
        <Border DockPanel.Dock="Top" Margin="0,0,0,6" Padding="8,5"
                CornerRadius="4" Background="#30FF9800"
                BorderBrush="#60FF9800" BorderThickness="1"
                IsVisible="{Binding HasCrossProjectWarning}"
                x:CompileBindings="False">
            <DockPanel>
                <Button DockPanel.Dock="Right" Content="Use original directory"
                        FontSize="11" Padding="8,2" Margin="8,0,0,0"
                        VerticalAlignment="Center"
                        Click="OnSwitchToOriginalClicked"/>
                <TextBlock Text="{Binding CrossProjectWarning}"
                           FontSize="11" TextWrapping="Wrap"
                           VerticalAlignment="Center" Opacity="0.9"/>
            </DockPanel>
        </Border>

        <!-- Search bar with inline icon -->
        <StackPanel DockPanel.Dock="Top" Spacing="4" Margin="0,0,0,8">
            <DockPanel>
                <TextBlock DockPanel.Dock="Left" Text="Search:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <Grid>
                    <views:NativeTextBox x:Name="SearchBox" Text="{Binding SearchText}"
                             Watermark="Search sessions..."
                             Padding="6,5,30,5"
                             KeyDown="OnSearchKeyDown"/>
                    <Button Content="&#x1F50D;" FontSize="11"
                            Width="26" Height="22" Padding="0"
                            HorizontalAlignment="Right" VerticalAlignment="Center"
                            Margin="0,0,3,0"
                            Background="Transparent" BorderThickness="0"
                            Opacity="0.5"
                            ToolTip.Tip="Search" Click="OnSearchButtonClicked"/>
                </Grid>
            </DockPanel>
            <ProgressBar Height="2" IsIndeterminate="True"
                         IsVisible="{Binding IsSearching}"/>
        </StackPanel>

        <!-- Status bar -->
        <TextBlock DockPanel.Dock="Top" Text="{Binding StatusMessage}" Opacity="0.7" FontSize="12"
                   Margin="0,0,0,2"/>

        <!-- Title generation progress -->
        <DockPanel DockPanel.Dock="Top" Margin="0,0,0,4"
                   IsVisible="{Binding IsGeneratingTitles}">
            <TextBlock DockPanel.Dock="Left" Text="{Binding TitleProgressText}"
                       FontSize="11" Opacity="0.6" VerticalAlignment="Center" Margin="0,0,8,0"/>
            <ProgressBar Minimum="0" Maximum="{Binding TitleProgressMax}" Value="{Binding TitleProgressValue}"
                         Height="4" VerticalAlignment="Center"/>
        </DockPanel>

        <!-- Bottom: Action buttons -->
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right"
                    Spacing="8" Margin="0,8,0,0">
            <Button Content="Import Selected" x:Name="ImportBtn" Click="OnImportClicked"
                    MinWidth="120" HorizontalContentAlignment="Center"/>
            <Button Content="Cancel" Click="OnCancelClicked"
                    MinWidth="80" HorizontalContentAlignment="Center"/>
        </StackPanel>

        <!-- Empty state -->
        <TextBlock Text="No Claude Code sessions found for this project directory."
                   IsVisible="{Binding HasNoItems}"
                   HorizontalAlignment="Center" VerticalAlignment="Center"
                   Opacity="0.5" FontSize="14"/>

        <!-- Main content: session list + preview -->
        <Grid RowDefinitions="*,Auto">

            <!-- Session list -->
            <ListBox Grid.Row="0"
                     ItemsSource="{Binding Items}"
                     SelectedItem="{Binding SelectedItem}"
                     Background="Transparent"
                     SelectionMode="Single">
                <ListBox.ItemTemplate>
                    <DataTemplate x:CompileBindings="False">
                        <Border Padding="8,6" Margin="0,1" CornerRadius="3"
                                Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}"
                                Opacity="{Binding RowOpacity}">
                            <Grid ColumnDefinitions="Auto,*,Auto" RowDefinitions="Auto,Auto">
                                <!-- Checkbox -->
                                <CheckBox Grid.Row="0" Grid.RowSpan="2" Grid.Column="0"
                                          IsChecked="{Binding IsSelected}"
                                          IsEnabled="{Binding IsSelectable}"
                                          VerticalAlignment="Center" Margin="0,0,8,0"/>

                                <!-- Title / preview -->
                                <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal" Spacing="6">
                                    <TextBlock Text="{Binding DisplayTitle}"
                                               TextTrimming="CharacterEllipsis"
                                               FontWeight="SemiBold"/>
                                    <TextBlock Text="generating..."
                                               IsVisible="{Binding IsTitlePending}"
                                               FontSize="11" FontStyle="Italic" Opacity="0.4"
                                               VerticalAlignment="Center"/>
                                </StackPanel>

                                <!-- Status badge (already imported / empty) -->
                                <TextBlock Grid.Row="0" Grid.Column="2"
                                           Text="{Binding StatusText}"
                                           IsVisible="{Binding StatusText, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                           FontSize="11" Opacity="0.6" FontStyle="Italic"
                                           VerticalAlignment="Center" Margin="8,0,0,0"/>

                                <!-- Date range + message count -->
                                <StackPanel Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="2"
                                            Orientation="Horizontal" Spacing="12" Margin="0,2,0,0">
                                    <TextBlock Text="{Binding DateRange}" FontSize="11" Opacity="0.6"/>
                                    <TextBlock Text="{Binding MessageCountText}" FontSize="11" Opacity="0.6"/>
                                    <TextBlock Text="{Binding ProjectLabel}"
                                               IsVisible="{Binding IsCrossProject}"
                                               FontSize="11" Opacity="0.5" FontStyle="Italic"
                                               Foreground="#5599DD"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <!-- Preview panel -->
            <Border Grid.Row="1"
                    IsVisible="{Binding HasPreview}"
                    BorderBrush="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                    BorderThickness="1"
                    CornerRadius="4"
                    Margin="0,8,0,0"
                    Padding="8"
                    MaxHeight="200">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="Preview" FontWeight="SemiBold"
                               FontSize="12" Opacity="0.7" Margin="0,0,0,4"/>
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding PreviewEntries}" x:CompileBindings="False">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Margin="0,2">
                                        <TextBlock Text="{Binding RoleLabel}"
                                                   FontWeight="SemiBold" FontSize="11"
                                                   Foreground="{DynamicResource SystemAccentColor}"
                                                   Opacity="0.8"/>
                                        <TextBlock Text="{Binding Content}"
                                                   TextWrapping="Wrap"
                                                   FontSize="12"
                                                   Opacity="0.9"
                                                   MaxLines="4"
                                                   TextTrimming="CharacterEllipsis"
                                                   Margin="8,0,0,4"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </DockPanel>
            </Border>

        </Grid>

    </DockPanel>

</Window>
