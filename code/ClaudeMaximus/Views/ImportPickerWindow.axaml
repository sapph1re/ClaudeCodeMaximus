<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:ClaudeMaximus.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        x:Class="ClaudeMaximus.Views.ImportPickerWindow"
        x:DataType="vm:ImportPickerViewModel"
        Title="Import Claude Sessions"
        Width="700" Height="550"
        MinWidth="500" MinHeight="400"
        WindowStartupLocation="CenterOwner">

    <DockPanel Margin="12">

        <!-- Top: Search bar -->
        <DockPanel DockPanel.Dock="Top" Margin="0,0,0,8">
            <TextBlock DockPanel.Dock="Left" Text="Search:" VerticalAlignment="Center" Margin="0,0,8,0"/>
            <ProgressBar DockPanel.Dock="Right" Width="24" Height="24" IsIndeterminate="True"
                         IsVisible="{Binding IsSearching}" Margin="8,0,0,0"/>
            <TextBox x:Name="SearchBox" Text="{Binding SearchText}"
                     Watermark="Enter search query and press Enter..."
                     KeyDown="OnSearchKeyDown"/>
        </DockPanel>

        <!-- Status bar -->
        <DockPanel DockPanel.Dock="Top" Margin="0,0,0,4">
            <TextBlock Text="{Binding StatusMessage}" Opacity="0.7" FontSize="12"/>
            <ProgressBar DockPanel.Dock="Right" Width="16" Height="16" IsIndeterminate="True"
                         IsVisible="{Binding IsGeneratingTitles}" Margin="8,0,0,0"
                         ToolTip.Tip="Generating session titles..."/>
        </DockPanel>

        <!-- Bottom: Action buttons -->
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right"
                    Spacing="8" Margin="0,8,0,0">
            <Button Content="Import Selected" x:Name="ImportBtn" Click="OnImportClicked"
                    MinWidth="120" HorizontalContentAlignment="Center"/>
            <Button Content="Cancel" Click="OnCancelClicked"
                    MinWidth="80" HorizontalContentAlignment="Center"/>
        </StackPanel>

        <!-- Empty state -->
        <TextBlock Text="No Claude Code sessions found for this project directory."
                   IsVisible="{Binding HasNoItems}"
                   HorizontalAlignment="Center" VerticalAlignment="Center"
                   Opacity="0.5" FontSize="14"/>

        <!-- Session list -->
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding Items}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:CompileBindings="False">
                        <Border Padding="8,6" Margin="0,1" CornerRadius="3"
                                Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}"
                                Opacity="{Binding RowOpacity}">
                            <Grid ColumnDefinitions="Auto,*,Auto" RowDefinitions="Auto,Auto">
                                <!-- Checkbox -->
                                <CheckBox Grid.Row="0" Grid.RowSpan="2" Grid.Column="0"
                                          IsChecked="{Binding IsSelected}"
                                          IsEnabled="{Binding IsSelectable}"
                                          VerticalAlignment="Center" Margin="0,0,8,0"/>

                                <!-- Title / preview -->
                                <TextBlock Grid.Row="0" Grid.Column="1"
                                           Text="{Binding DisplayTitle}"
                                           TextTrimming="CharacterEllipsis"
                                           FontWeight="SemiBold"/>

                                <!-- Status badge (already imported / empty) -->
                                <TextBlock Grid.Row="0" Grid.Column="2"
                                           Text="{Binding StatusText}"
                                           IsVisible="{Binding StatusText, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                           FontSize="11" Opacity="0.6" FontStyle="Italic"
                                           VerticalAlignment="Center" Margin="8,0,0,0"/>

                                <!-- Date range + message count -->
                                <StackPanel Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="2"
                                            Orientation="Horizontal" Spacing="12" Margin="0,2,0,0">
                                    <TextBlock Text="{Binding DateRange}" FontSize="11" Opacity="0.6"/>
                                    <TextBlock Text="{Binding MessageCountText}" FontSize="11" Opacity="0.6"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

    </DockPanel>

</Window>
