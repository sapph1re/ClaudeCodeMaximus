<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="ClaudeMaximus.Views.InputDialog"
        Title="Name"
        Width="320" Height="130"
        CanResize="False"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">

    <StackPanel Margin="14" Spacing="10">
        <TextBlock x:Name="PromptLabel" Text="Enter a name:"/>
        <TextBox x:Name="InputBox" KeyDown="OnKeyDown"/>
        <StackPanel Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Spacing="8">
            <Button Content="Cancel" Click="OnCancel" IsCancel="True"/>
            <Button Content="OK" Click="OnOk" IsDefault="True"/>
        </StackPanel>
    </StackPanel>

</Window>
